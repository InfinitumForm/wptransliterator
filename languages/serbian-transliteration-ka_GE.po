msgstr "Multibyte String-ის დაყენება"

#: classes/requirements.php:177
msgid "this PHP extension"
msgstr "ეს PHP გაფართოება"

#: classes/requirements.php:200
#, php-format
msgid ""
"The %1$s cannot run on WordPress versions older than %2$s. Please update "
