#. Plugin Name of the plugin/theme
msgid "Transliterator – Multilingual and Multi-script Text Conversion"
msgstr "Transliterator — многоязычное и многоскриптовое преобразование текста"

#. Plugin URI of the plugin/theme
msgid "https://wordpress.org/plugins/serbian-transliteration/"
msgstr "https://wordpress.org/plugins/serbian-transliteration/"

#. Description of the plugin/theme
msgid ""
"Universal WordPress transliteration for multilingual and non-Latin URLs, "
"permalinks, media, search and full site content into SEO-friendly readable "
"text."
msgstr ""
"Универсальная WordPress транслитерация для многоязычных и нелатинских URL-"
"адресов, постоянных ссылок, медиафайлов, поиска и полного содержимого сайта "
"в SEO-оптимизированный читаемый текст."

#. Author of the plugin/theme
msgid "Ivijan-Stefan Stipić"
msgstr "Ivijan-Stefan Stipić"

#. Author URI of the plugin/theme
msgid "https://profiles.wordpress.org/ivijanstefan/"
msgstr "https://profiles.wordpress.org/ivijanstefan/"

